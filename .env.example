# Exemplo de configuração local (não versionar o arquivo .env real)
DB_HOST=seu_host
DB_PORT=5432
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_SCHEMA=kinghost_octadesk
GEMINI_API_KEY=sua_chave_gemini
GEMINI_MODEL=gemini-flash-latest
NPS_META=70.0
NPS_MIN_AVALIACOES=3
NPS_PERIODO_TIPO=mes_anterior
ANALISE_MAX_DATASET_SIZE=12000
ANALISE_MAX_TENTATIVAS=5
ANALISE_DELAY_TENTATIVA=5
LOG_FILE_LEVEL=DEBUG
LOG_CONSOLE_LEVEL=INFO
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5
