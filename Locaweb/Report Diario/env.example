# ==============================================
# CONFIGURAÇÕES DO BANCO DE DADOS POSTGRESQL
# ==============================================
DB_SERVER=seu.servidor.banco.exemplo.com
DB_DATABASE=nome_do_banco
DB_USER=seu_usuario
DB_PASSWORD=sua_senha

# ==============================================
# CONFIGURAÇÕES DO SLACK
# ==============================================
# Token do bot (xoxb-...) - NUNCA COMPARTILHE!
SLACK_BOT_TOKEN=xoxb-seu-token-aqui

# IDs de canal do Slack
# Canal: prefixo C... | Usuário (DM): prefixo U...
SLACK_CHANNEL_ID=C00000000
SLACK_CHANNEL_ID_TESTE=C00000000

# ==============================================
# AMBIENTE DE EXECUÇÃO
# ==============================================
# test       → envia somente para o canal de teste (default seguro)
# production → envia para o canal oficial
# both       → envia para teste e produção simultaneamente
APP_ENV=test

# ==============================================
# CONFIGURAÇÕES DO RELATÓRIO
# ==============================================
# Período usado como baseline para comparação (formato: YYYY-MM-DD)
PADRAO_DATA_INICIO=2025-08-01
PADRAO_DATA_FIM=2025-10-31

# ==============================================
# MENSAGEM FINAL (opcional)
# ==============================================
# URL para o relatório completo (Power BI, Looker, etc.).
# Se vazio, o botão "Relatório Completo" não aparece na mensagem do Slack.
POWERBI_REPORT_URL=

# E-mail de suporte mostrado na mensagem final.
# Se vazio, o app omite a referência ao e-mail.
SUPPORT_EMAIL=

# ==============================================
# CONFIGURAÇÕES DE LOGGING
# ==============================================
LOG_LEVEL=INFO
LOG_FILE=report_diario.log
